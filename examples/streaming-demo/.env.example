# Supabase project credentials
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.

# Your Supabase project URL (from Dashboard → Settings → API)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co

# Supabase anon/public key (from Dashboard → Settings → API)
VITE_SUPABASE_ANON_KEY=eyJ...

# UUID of the building to render (from supabase/seed.sql or your own INSERT)
VITE_BUILDING_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# ── Local development (supabase start) ──
# Uncomment these to use the local Supabase stack instead of a cloud project.
#
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=eyJ...   # printed by `supabase start`
